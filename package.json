{
  "name": "@u83ism/architecture-rules",
  "version": "0.1.0",
  "description": "Shared architecture rule definitions for Slime Architecture — levels, layers, folder patterns, and severity types.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "build:rules": "tsx scripts/build-rules.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "slime-architecture",
    "architecture",
    "linter",
    "typescript"
  ],
  "license": "MIT"
}
